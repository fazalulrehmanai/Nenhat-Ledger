rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Default Deny
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isEmailVerified() {
      return request.auth.token.email_verified == true;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // --- User Validation ---
    function isValidUser(data) {
      return data.fullName is string && data.fullName.size() <= 100
          && data.email is string && data.email.size() <= 100
          && data.mobile is string && data.mobile.size() <= 20
          && data.plan in ['Free', 'Pro']
          && (data.entryCount is int && data.entryCount >= 0);
    }

    // --- Entry Validation ---
    function isValidEntry(data) {
      return data.name is string && data.name.size() > 0 && data.name.size() <= 100
          && data.fatherName is string && data.fatherName.size() > 0 && data.fatherName.size() <= 100
          && data.amount is number && data.amount > 0
          && data.village is string && data.village.size() > 0 && data.village.size() <= 100
          && (data.caste == null || (data.caste is string && data.caste.size() <= 100))
          && data.year is int && data.year >= 1900 && data.year <= 2100
          && data.type in ['sent', 'received'];
    }

    // --- Matches ---

    // User Profile
    match /users/{userId} {
      allow get: if isOwner(userId);
      allow create: if isOwner(userId) 
                    && isValidUser(request.resource.data)
                    && request.resource.data.plan == 'Free'
                    && request.resource.data.entryCount == 0;
      allow update: if isOwner(userId)
                    && isValidUser(request.resource.data)
                    && request.resource.data.email == resource.data.email // Email immutable for ledger
                    && (
                      // Only allow incrementing entryCount if not changing plan here
                      (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['entryCount', 'fullName', 'mobile']))
                    );
    }

    // Ledger Entries
    match /users/{userId}/entries/{entryId} {
      allow list: if isOwner(userId);
      allow get: if isOwner(userId);

      allow create: if isOwner(userId) 
                    && isEmailVerified()
                    && isValidEntry(request.resource.data)
                    && isValidId(entryId)
                    // Check limit for free plan
                    && (get(/databases/$(database)/documents/users/$(userId)).data.plan == 'Pro' 
                        || get(/databases/$(database)/documents/users/$(userId)).data.entryCount < 20);

      allow update: if isOwner(userId)
                    && isEmailVerified()
                    && isValidEntry(request.resource.data)
                    && request.resource.data.diff(resource.data).affectedKeys().hasAll([]) 
                    // Entries are fully editable per request
                    ;

      allow delete: if isOwner(userId) && isEmailVerified();
    }
  }
}
