rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // catch-all deny
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---
    function isSignedIn() { return request.auth != null; }
    function isVerified() { return isSignedIn() && request.auth.token.email_verified == true; }
    function isOwner(userId) { return isSignedIn() && request.auth.uid == userId; }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }

    function isValidUser(data) {
      return data.keys().hasAll(['fullName', 'email', 'mobileNumber', 'plan', 'entryCount'])
        && data.keys().size() == 5
        && data.fullName is string && data.fullName.size() <= 128
        && data.email == request.auth.token.email
        && data.mobileNumber is string && data.mobileNumber.size() <= 20
        && data.plan in ['free', 'pro']
        && data.entryCount is int;
    }

    function isValidEntry(data, userId) {
      return data.keys().hasAll(['userId', 'giverName', 'fatherName', 'amount', 'cityVillage', 'suggestedReturn', 'createdAt', 'updatedAt'])
        && data.userId == userId
        && data.giverName is string && data.giverName.size() <= 128
        && data.fatherName is string && data.fatherName.size() <= 128
        && data.amount is number && data.amount >= 0
        && data.cityVillage is string && data.cityVillage.size() <= 128
        && (data.caste == null || (data.caste is string && data.caste.size() <= 64))
        && data.suggestedReturn is number && data.suggestedReturn >= 0
        && data.createdAt == request.time
        && data.updatedAt == request.time;
    }

    // --- User Profiles ---
    match /users/{userId} {
      allow get: if isOwner(userId);
      allow create: if isOwner(userId) && isValidUser(incoming()) && incoming().plan == 'free' && incoming().entryCount == 0;
      allow update: if isOwner(userId) && isValidUser(incoming()) 
        && (
          // Action: Profile Update
          (incoming().diff(existing()).affectedKeys().hasOnly(['fullName', 'mobileNumber', 'updatedAt'])) ||
          // Action: Internal Count Sync (Usually handled by app logic, but rules must allow)
          (incoming().diff(existing()).affectedKeys().hasOnly(['entryCount', 'updatedAt']))
        );
    }

    // --- Entries ---
    match /users/{userId}/entries/{entryId} {
      allow list: if isOwner(userId) && isVerified();
      allow get: if isOwner(userId) && isVerified();
      
      allow create: if isOwner(userId) && isVerified() && isValidId(entryId) 
        && isValidEntry(incoming(), userId)
        && (
          get(/databases/$(database)/documents/users/$(userId)).data.plan == 'pro' ||
          get(/databases/$(database)/documents/users/$(userId)).data.entryCount < 20
        );

      allow update: if isOwner(userId) && isVerified() && isValidId(entryId)
        && incoming().userId == userId
        && incoming().createdAt == existing().createdAt
        && incoming().updatedAt == request.time
        && incoming().giverName is string && incoming().giverName.size() <= 128
        && incoming().fatherName is string && incoming().fatherName.size() <= 128
        && incoming().amount is number && incoming().amount >= 0
        && (incoming().caste == null || (incoming().caste is string && incoming().caste.size() <= 64))
        && incoming().suggestedReturn is number && incoming().suggestedReturn >= 0;

      allow delete: if isOwner(userId) && isVerified();
    }
  }
}
