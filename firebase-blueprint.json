{
  "entities": {
    "User": {
      "title": "User Profile",
      "description": "Stores user core profile information.",
      "type": "object",
      "properties": {
        "fullName": { "type": "string", "description": "Full name of the user" },
        "email": { "type": "string", "format": "email" },
        "mobile": { "type": "string", "description": "Mobile number" },
        "plan": { "type": "string", "enum": ["Free", "Pro"], "description": "Subscription plan" },
        "entryCount": { "type": "integer", "description": "Current number of entries for free plan limit" }
      },
      "required": ["fullName", "email", "plan"]
    },
    "Entry": {
      "title": "Ledger Entry",
      "description": "A single ledger record for Nenhat.",
      "type": "object",
      "properties": {
        "name": { "type": "string", "description": "Giver's Name" },
        "fatherName": { "type": "string", "description": "Father's Name" },
        "amount": { "type": "number", "description": "Amount in PKR" },
        "village": { "type": "string", "description": "City or Village" },
        "caste": { "type": "string", "description": "Caste (Optional)" },
        "year": { "type": "integer", "description": "Year of transaction" },
        "type": { "type": "string", "enum": ["sent", "received"], "description": "Transaction type" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "fatherName", "amount", "village", "year", "type"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profile document"
    },
    "/users/{userId}/entries/{entryId}": {
      "schema": "Entry",
      "description": "Individual ledger entry for a specific user"
    }
  }
}
